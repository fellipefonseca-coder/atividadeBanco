public class ContaPoupanca extends Conta {

    public ContaPoupanca(double saldoInicial) {
        super(saldoInicial);
    }

    // Sobrescrita
    @Override
    public void sacar(double valor) {
        if (valor <= saldo) {
            saldo -= valor;
            System.out.println("Saque Conta Poupança (sem taxa). Saldo: " + saldo);
        } else {
            System.out.println("Saldo insuficiente na Poupança.");
        }
    }

    // Sobrecarga
    @Override
    public void sacar(double valor, double taxa) {
        // Poupança normalmente não usa taxa, mas implementando só pra cumprir a tarefa
        super.sacar(valor, taxa);
    }
}
